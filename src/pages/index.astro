  <script is:inline>
  function toggleFaq(btn) {
    const item = btn.closest('.faq-item');
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
    if (!isOpen) item.classList.add('open');
  }

  // Consultation form submission to the Make webhook (AJAX, stays on page)
  (function() {
    const form = document.getElementById('consultation-form');
    if (!form) return;
    const submitBtn = form.querySelector('.form-submit');
    const successBox = document.getElementById('form-success');
    const errorBox = document.getElementById('form-error');

    // Conditional follow-ups for "How did you find us?"
    // Hidden blocks keep their fields disabled, so they are skipped by
    // validation and excluded from the submission.
    const sourceSelect = document.getElementById('referral_source');
    const llmBlock = document.getElementById('llm-followup');
    const otherBlock = document.getElementById('other-followup');

    function toggleBlock(block, show) {
      block.classList.toggle('active', show);
      block.querySelectorAll('input, select, textarea').forEach(el => {
        el.disabled = !show;
        if (!show) el.value = '';
      });
    }

    sourceSelect.addEventListener('change', function() {
      toggleBlock(llmBlock, this.value.indexOf('AI assistant') === 0);
      toggleBlock(otherBlock, this.value === 'Other');
    });

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      errorBox.classList.remove('active');

      // Native validation
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const originalLabel = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' }
        });

        if (response.ok) {
          form.style.display = 'none';
          successBox.classList.add('active');
          successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
          // Track successful form submission
          plausible('Form Submitted', { props: {
            referral_source: (document.getElementById('referral_source') || {}).value || 'unknown'
          }});
        } else {
          throw new Error('Submission failed');
        }
      } catch (err) {
        errorBox.classList.add('active');
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
      }
    });
  })();

  // ── Service card expand + prefill ──────────────────────────────────
  (function() {
    var cards = document.querySelectorAll('.service-card.expandable');
    cards.forEach(function(card) {
      card.addEventListener('click', function(e) {
        // If the button was clicked, prefill + scroll instead of just toggling
        if (e.target.closest('.service-detail-btn')) {
          e.preventDefault();
          var service = card.getAttribute('data-service') || '';
          var box = document.getElementById('situation');
          if (box) {
            var prefix = 'I would like help with: ' + service + '. ';
            // Only prefill if the user hasn't already typed something
            if (!box.value.trim()) {
              box.value = prefix;
            } else if (box.value.indexOf(service) === -1) {
              box.value = prefix + box.value;
            }
          }
          var form = document.getElementById('book');
          if (form) form.scrollIntoView({ behavior: 'smooth', block: 'start' });
          if (box) setTimeout(function(){ box.focus(); }, 500);
          if (typeof plausible === 'function') {
            plausible('Service Interest', { props: { service: service } });
          }
          return;
        }
        // Otherwise toggle this card's detail panel (accordion: close others)
        var isOpen = card.classList.contains('open');
        cards.forEach(function(c){ c.classList.remove('open'); });
        if (!isOpen) card.classList.add('open');
      });
    });
  })();

  // Deferred so the Plausible deferred script is guaranteed to be ready.
  function initTracking() {
    if (typeof plausible !== 'function') {
      return setTimeout(initTracking, 100);
    }

    // Scroll depth — fires once per milestone per page load
    var milestones = [25, 50, 75, 90];
    var reached = {};
    function getScrollPct() {
      var el = document.documentElement;
      var scrolled = el.scrollTop || document.body.scrollTop;
      var total = el.scrollHeight - el.clientHeight;
      return total > 0 ? Math.round((scrolled / total) * 100) : 0;
    }
    function onScroll() {
      var pct = getScrollPct();
      milestones.forEach(function(m) {
        if (!reached[m] && pct >= m) {
          reached[m] = true;
          plausible('Scroll Depth', { props: { milestone: m + '%' } });
        }
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    // CTA clicks — records label text and page section
    document.querySelectorAll('a[href="#book"]').forEach(function(el) {
      el.addEventListener('click', function() {
        var section = 'unknown';
        var node = el.closest('section, nav, footer, div[class]');
        if (node) {
          var id = node.id || node.className.split(' ')[0];
          section = id || 'unknown';
        }
        plausible('CTA Clicked', { props: {
          label: el.textContent.trim().substring(0, 60),
          section: section
        }});
      });
    });
  }

  // Kick off after DOM is fully ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { setTimeout(initTracking, 0); });
  } else {
    setTimeout(initTracking, 0);
  }  </script>

