---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import NewsletterPopup from '../../components/NewsletterPopup.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---
<BaseLayout
  title="Greek Tax Guides for Expats | MyGreekTax Blog"
  description="Plain-English guides to Greek taxes, AFM registration, tax residency, freelancer setup and more, written for expats and foreign residents in Greece."
  canonicalPath="/blog/"
>
  <Header isHome={false} />

  <main class="blog-index">
    <p class="blog-eyebrow">Guides & resources</p>
    <h1>Greek tax, explained <em>in plain English.</em></h1>
    <p class="blog-sub">Practical guides for expats, nomads and foreign residents navigating the Greek tax system. No jargon, no Greek required.</p>

    <div class="blog-grid">
      {posts.map((post) => (
        <a class="blog-card" href={`/blog/${post.slug}/`}>
          <p class="blog-card-category">{post.data.category}</p>
          <h2>{post.data.title}</h2>
          <p class="blog-card-desc">{post.data.description}</p>
          <p class="blog-card-meta">{dateFmt(post.data.pubDate)} · {post.data.readingTime}</p>
          <span class="blog-card-link">Read guide →</span>
        </a>
      ))}
    </div>

    <p class="blog-back"><a href="/">← Back to MyGreekTax</a></p>
  </main>

  <Footer />
  <NewsletterPopup />
</BaseLayout>

<style>
  .blog-index { max-width: 880px; margin: 0 auto; padding: 100px 24px 80px; }
  .blog-eyebrow { font-size: 13px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--amber); font-weight: 500; }
  .blog-index h1 { font-family: var(--serif); font-size: clamp(34px, 5vw, 52px); margin: 12px 0 20px; line-height: 1.1; }
  .blog-index h1 em { color: var(--amber); font-style: italic; }
  .blog-sub { font-size: 17px; opacity: 0.75; max-width: 560px; margin-bottom: 48px; }
  .blog-grid { display: grid; gap: 24px; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); margin-bottom: 24px; }
  .blog-card {
    display: block; background: var(--white); border: 1px solid var(--night-15);
    border-radius: 12px; padding: 28px; text-decoration: none; color: var(--night);
    transition: transform .15s ease, box-shadow .15s ease;
  }
  .blog-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(30,42,58,0.08); }
  .blog-card-category { font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--sage); font-weight: 500; margin-bottom: 10px; }
  .blog-card h2 { font-family: var(--serif); font-size: 22px; line-height: 1.25; margin-bottom: 10px; }
  .blog-card-desc { font-size: 15px; opacity: 0.75; margin-bottom: 16px; }
  .blog-card-meta { font-size: 13px; opacity: 0.55; margin-bottom: 12px; }
  .blog-card-link { font-size: 14px; font-weight: 500; color: var(--amber); }
  .blog-back { margin-top: 16px; font-size: 14px; }
  .blog-back a { color: var(--night); opacity: 0.7; }
</style>
