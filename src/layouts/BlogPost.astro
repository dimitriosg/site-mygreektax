---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsletterPopup from '../components/NewsletterPopup.astro';

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  category: string;
  pubDate: Date;
  updatedDate?: Date;
  readingTime?: string;
  slug: string;
}

const { title, seoTitle, description, category, pubDate, updatedDate, readingTime, slug } = Astro.props;

const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---
<BaseLayout
  title={seoTitle ?? `${title} | MyGreekTax`}
  description={description}
  ogType="article"
  canonicalPath={`/blog/${slug}/`}
>
  <Header isHome={false} />

  <main class="post">
    <div class="post-breadcrumb">
      <a href="/">MyGreekTax</a> › <a href="/blog/">Blog</a> › {title}
    </div>

    <article class="post-article">
      <p class="post-category">{category}</p>
      <h1>{title}</h1>
      <p class="post-meta">
        {[
          `Published ${dateFmt(pubDate)}`,
          updatedDate ? `Updated ${dateFmt(updatedDate)}` : null,
          readingTime,
          'By MyGreekTax',
        ].filter(Boolean).join(' · ')}
      </p>

      <div class="post-body">
        <slot />
      </div>
    </article>

    <p class="post-back"><a href="/">← Back to MyGreekTax</a></p>
  </main>

  <Footer />
  <NewsletterPopup />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    'headline': title,
    'description': description,
    'datePublished': pubDate.toISOString(),
    'dateModified': (updatedDate ?? pubDate).toISOString(),
    'author': { '@type': 'Organization', 'name': 'MyGreekTax', 'url': 'https://mygreektax.eu' },
    'publisher': { '@type': 'Organization', 'name': 'MyGreekTax', 'url': 'https://mygreektax.eu', 'logo': { '@type': 'ImageObject', 'url': 'https://mygreektax.eu/og-image.png' } },
    'mainEntityOfPage': { '@type': 'WebPage', '@id': 'https://mygreektax.eu/blog/' + slug + '/' },
    'image': 'https://mygreektax.eu/og-image.png',
    'url': 'https://mygreektax.eu/blog/' + slug + '/'
  })} />


  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    'itemListElement': [
      { '@type': 'ListItem', 'position': 1, 'name': 'MyGreekTax', 'item': 'https://mygreektax.eu/' },
      { '@type': 'ListItem', 'position': 2, 'name': 'Blog', 'item': 'https://mygreektax.eu/blog/' },
      { '@type': 'ListItem', 'position': 3, 'name': title, 'item': 'https://mygreektax.eu/blog/' + slug + '/' }
    ]
  })} />

</BaseLayout>

<style>
  .post { max-width: 760px; margin: 0 auto; padding: 100px 24px 80px; }
  .post-breadcrumb { font-size: 13px; color: var(--night); opacity: 0.6; margin-bottom: 24px; }
  .post-breadcrumb a { color: inherit; }
  .post-category {
    font-family: var(--sans); font-size: 13px; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--amber); font-weight: 500; margin-bottom: 12px;
  }
  .post-article h1 {
    font-family: var(--serif); font-size: clamp(30px, 4vw, 44px); line-height: 1.15;
    margin-bottom: 16px;
  }
  .post-meta { font-size: 14px; opacity: 0.65; margin-bottom: 40px; }
  .post-body { font-size: 17px; line-height: 1.75; }
  .post-body h2 {
    font-family: var(--serif); font-size: 28px; margin: 48px 0 16px;
  }
  .post-body h3 { font-family: var(--serif); font-size: 21px; margin: 32px 0 12px; }
  .post-body p { margin-bottom: 20px; }
  .post-body ul, .post-body ol { margin: 0 0 20px 22px; }
  .post-body li { margin-bottom: 8px; }
  .post-body table { width: 100%; border-collapse: collapse; margin: 24px 0; font-size: 15px; }
  .post-body th, .post-body td { border: 1px solid var(--night-15); padding: 10px 12px; text-align: left; }
  .post-body th { background: var(--linen); }
  .post-body a { color: var(--amber); text-decoration: underline; }
  .post-body strong { font-weight: 500; }
  .post-back { margin-top: 48px; font-size: 14px; }
  .post-back a { color: var(--night); opacity: 0.7; }
</style>
